# AppointmentTrader
AT_API_KEY=your_appointmenttrader_api_key

# Anthropic (Claude Agent SDK)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gmail IMAP — no OAuth, just an app password
# Setup (60 seconds):
#   1. myaccount.google.com/security → 2-Step Verification → App passwords
#   2. Create an app password named "AT Edge"
#   3. Copy the 16-character password below
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Neon Postgres — 3-Tier Memory System
# Create at https://console.neon.tech and paste the connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/at_edge?sslmode=require

# Agent settings
DRY_RUN=true
AUTO_APPROVE_BELOW_USD=0
DEFAULT_PROFIT_BASIS_POINTS=10000

# Optional
APIFY_API_TOKEN=                  # Enables restaurant profile enrichment
ANTHROPIC_MODEL=claude-sonnet-4-20250514
