# AppointmentTrader
AT_API_KEY=your_appointmenttrader_api_key

# Anthropic (Claude Agent SDK)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gmail OAuth (for email import)
GMAIL_CLIENT_ID=your_google_client_id
GMAIL_CLIENT_SECRET=your_google_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Gmail label to monitor for forwarded reservation confirmations
GMAIL_IMPORT_LABEL=AT-Import

# Neon Postgres — 3-Tier Memory System
# Create a new database at https://console.neon.tech and paste the connection string
# Migration runs automatically on server startup
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/at_edge?sslmode=require

# Agent settings
DRY_RUN=true
AUTO_APPROVE_BELOW_USD=0
DEFAULT_PROFIT_BASIS_POINTS=10000
