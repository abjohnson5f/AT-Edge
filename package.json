{
  "name": "at-edge",
  "version": "0.1.0",
  "description": "AppointmentTrader intelligent market-making agent powered by Claude Agent SDK",
  "type": "module",
  "scripts": {
    "build": "tsc && cd ui && npm run build",
    "build:check": "tsc",
    "start": "NODE_ENV=production node --import tsx server/index.ts",
    "server": "tsx watch server/index.ts",
    "ui": "cd ui && npm run dev",
    "dev": "npm run server & npm run ui",
    "cli": "tsx src/index.ts",
    "scout": "tsx src/index.ts scout",
    "import": "tsx src/index.ts import",
    "portfolio": "tsx src/index.ts portfolio",
    "price-check": "tsx src/index.ts price-check",
    "backfill": "tsx server/backfill.ts",
    "db:migrate": "tsx -e \"import{runMigration}from'./server/db/client.js';import'dotenv/config';runMigration().then(()=>{console.log('Migration complete');process.exit(0)}).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "googleapis": "^148.0.0",
    "imapflow": "^1.2.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
